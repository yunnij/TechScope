{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "@cloudflare/workers-types"
    ],
    "verbatimModuleSyntax": true
  },
  "include": [
    "functions/**/*.ts",
    "shared/**/*.ts",
    "workers/**/*.ts"
  ]
}
